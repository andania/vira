# =====================================================
# SERVER CONFIGURATION
# =====================================================
NODE_ENV=development
PORT=3000
API_VERSION=v1
API_PREFIX=/api
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/viraz
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT=10000
DATABASE_CONNECTION_TIMEOUT=30000

# =====================================================
# REDIS CONFIGURATION
# =====================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=viraz:

# =====================================================
# JWT AUTHENTICATION
# =====================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=viraz-platform
JWT_AUDIENCE=viraz-users

# =====================================================
# EMAIL CONFIGURATION
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@viraz.com
SMTP_FROM_NAME=Viraz Platform

# =====================================================
# SMS CONFIGURATION (Twilio)
# =====================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=

# =====================================================
# PUSH NOTIFICATIONS (Firebase)
# =====================================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# =====================================================
# PAYMENT GATEWAYS
# =====================================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox  # sandbox or live
PAYPAL_WEBHOOK_ID=your-webhook-id

FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
FLUTTERWAVE_ENCRYPTION_KEY=your-encryption-key

PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# =====================================================
# FILE STORAGE
# =====================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=viraz-media
AWS_S3_BUCKET_URL=https://viraz-media.s3.amazonaws.com

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# =====================================================
# MONITORING & ANALYTICS
# =====================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456
NEW_RELIC_LICENSE_KEY=your-new-relic-key
NEW_RELIC_APP_NAME=Viraz Platform

# =====================================================
# RATE LIMITING
# =====================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PUBLIC=10
RATE_LIMIT_MAX_AUTH=100
RATE_LIMIT_MAX_SPONSOR=500
RATE_LIMIT_MAX_ADMIN=1000

# =====================================================
# SECURITY
# =====================================================
BCRYPT_ROUNDS=10
SESSION_SECRET=your-session-secret
ENCRYPTION_KEY=your-32-character-encryption-key
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900000  # 15 minutes in milliseconds

# =====================================================
# FEATURE FLAGS
# =====================================================
ENABLE_2FA=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PHONE_VERIFICATION=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_LIVE_STREAMING=true
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_MARKETPLACE=true
ENABLE_GAMIFICATION=true

# =====================================================
# BACKGROUND JOBS
# =====================================================
CAP_DECAY_JOB_SCHEDULE=0 0 * * *  # Daily at midnight
LEADERBOARD_JOB_SCHEDULE=0 * * * *  # Hourly
ANALYTICS_JOB_SCHEDULE=0 0 * * *  # Daily
NOTIFICATION_JOB_SCHEDULE=* * * * *  # Every minute

# =====================================================
# THIRD-PARTY INTEGRATIONS
# =====================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key